{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiMi Nox",
  "version": "1.0.0",
  "identifier": "de.mimiai.mimi-nox",
  "build": {
    "beforeDevCommand": "python run_server.py --reload",
    "devUrl": "http://localhost:8765",
    "beforeBuildCommand": "python run_server.py",
    "frontendDist": "../app/src"
  },
  "app": {
    "windows": [
      {
        "title": "◑ MiMi Nox",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
